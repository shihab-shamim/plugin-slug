{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "icb/fold-out-reveal",
	"version": "1.0.0",
	"title": "3D Fold Out Reveal",
	"category": "widgets",
	"description": "3D Fold Out Reveal is a WordPress plugin that allows you to create 3D fold out reveal effects on your website.",
	"keywords": [
		"3D Fold Out Reveal","fold","reveal","cards"
	],
	"textdomain": "info-cards",
	"attributes": {
		"alignment": {
			"type": "string",
			"default": "center"
		},
		"purposeType": {
			"type": "string",
			"default": "test"
		},
		"colors":{
			"type":"object",
			"default":{
				"color": "black",
				"bg": "#B1C5A4"
			}
		}
	},
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"html": false
	},
	"example": {
		"attributes": {}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./view.css",
	"render": "file:./render.php",
	"viewScript": "file:./view.js"
}